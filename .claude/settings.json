{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "tempyr validate --json",
            "type": "command"
          },
          {
            "command": "tempyr index update --json",
            "type": "command"
          }
        ],
        "matcher": "mcp__tempyr__graph_add_node|mcp__tempyr__graph_update_node|mcp__tempyr__graph_add_edge|mcp__tempyr__interview_commit"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "tempyr journal finalize --quiet --json",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "tempyr journal bootstrap --quiet --json",
            "type": "command"
          }
        ]
      }
    ]
  }
}
