{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:maestro.session-ended",
  "title": "maestro.session-ended",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cost_usd": {
      "type": "number"
    },
    "tool_calls_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "Maestro session closed (done | budget-exceeded | interrupted | fatal).",
  "required": [
    "session_id",
    "outcome",
    "duration_ms",
    "input_tokens",
    "output_tokens",
    "cost_usd",
    "tool_calls_count",
    "ended_at"
  ]
}
