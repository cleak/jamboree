{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:maestro.tool-call",
  "title": "maestro.tool-call",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "success": {
      "type": "boolean"
    },
    "error_kind": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "Maestro invoked a tool service via NATS request-reply (every call is journaled).",
  "required": [
    "session_id",
    "tool_name",
    "duration_ms",
    "success",
    "ts"
  ]
}
