{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:patch.rollback-requested",
  "title": "patch.rollback-requested",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "service": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "requested_by": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "Caller asks the patch-agent to roll back a service to the previous routing manifest revision (\u00a720.4).",
  "required": [
    "service",
    "reason",
    "requested_by",
    "ts"
  ]
}
