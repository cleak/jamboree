{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:picker.errored",
  "title": "picker.errored",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "error_kind": {
      "type": "string"
    },
    "detail": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "Picker raised an internal error before exit \u2014 Maestro wakes on this.",
  "required": [
    "session_id",
    "task_id",
    "error_kind",
    "detail",
    "ts"
  ]
}
