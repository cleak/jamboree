{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:picker.exited",
  "title": "picker.exited",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295
    },
    "exited_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    }
  },
  "description": "Picker process exited normally (zero or non-zero, but not killed).",
  "required": [
    "session_id",
    "task_id",
    "exit_code",
    "exited_at",
    "duration_ms"
  ]
}
