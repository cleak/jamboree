{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:pr.merge-conflict-detected",
  "title": "pr.merge-conflict-detected",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "pr_ref": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "head_sha": {
      "type": "string"
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "pr-status-poller observed mergeable_state=dirty on an open PR, indicating merge conflicts with the base branch.",
  "required": [
    "pr_ref",
    "task_id",
    "head_sha",
    "detected_at"
  ]
}
