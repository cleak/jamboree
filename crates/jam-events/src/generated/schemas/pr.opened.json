{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:pr.opened",
  "title": "pr.opened",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string"
    },
    "pr_ref": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "Picker opened a PR via `open-pr` tool or `gh pr create` from the worktree.",
  "required": [
    "task_id",
    "pr_ref",
    "branch",
    "title",
    "draft",
    "opened_at"
  ]
}
