{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:quota.exhausted",
  "title": "quota.exhausted",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "harness": {
      "type": "string"
    },
    "window_kind": {
      "type": "string"
    },
    "resets_at": {
      "type": "string",
      "format": "date-time"
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "A harness's window is exhausted (Codex 5h window full, Claude rate-limit hit, API budget cap).",
  "required": [
    "harness",
    "window_kind",
    "detected_at"
  ]
}
