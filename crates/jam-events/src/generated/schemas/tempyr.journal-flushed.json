{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-events:tempyr.journal-flushed",
  "title": "tempyr.journal-flushed",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  },
  "description": "tempyr journal flush published one or more sessions to refs/tempyr/journals/archive/*.",
  "required": [
    "session_count",
    "ts"
  ]
}
