{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-tools:message.full-stop.request",
  "title": "message.full-stop request",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "reason"],
  "properties": {
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "reason": { "type": "string", "minLength": 1, "maxLength": 8000 },
    "from": { "type": "string", "minLength": 1, "maxLength": 128 },
    "requested_by": { "type": "string", "minLength": 1, "maxLength": 128 }
  }
}
