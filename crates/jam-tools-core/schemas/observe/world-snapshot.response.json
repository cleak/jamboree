{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-tools:observe.world-snapshot.response",
  "title": "observe.world-snapshot response",
  "type": "object",
  "additionalProperties": true,
  "required": ["task_id", "captured_at", "trace_id", "readiness"],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "format": "date-time" },
    "trace_id": { "type": "string", "minLength": 26, "maxLength": 26 },
    "readiness": { "type": "object", "additionalProperties": true }
  }
}
