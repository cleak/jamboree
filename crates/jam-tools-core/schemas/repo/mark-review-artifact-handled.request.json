{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-tools:repo.mark-review-artifact-handled.request",
  "title": "repo.mark-review-artifact-handled request",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "status", "reasoning"],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["Open", "Acknowledged", "Addressed", "Dismissed"]
    },
    "reasoning": { "type": "string", "minLength": 1 }
  }
}
