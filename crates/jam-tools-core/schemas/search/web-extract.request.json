{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jam-tools:search.web-extract.request",
  "title": "search.web-extract request",
  "type": "object",
  "additionalProperties": false,
  "required": ["urls"],
  "properties": {
    "urls": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "type": "string", "format": "uri", "minLength": 1 }
    },
    "render_js": { "type": "boolean" },
    "include_images": { "type": "boolean" }
  }
}
