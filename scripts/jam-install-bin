#!/usr/bin/env bash
# /opt/jam/sbin/jam-install-bin — root-installed wrapper invoked by caleb or
# maestro via NOPASSWD sudo to install first-party binaries into /opt/jam/bin/.
#
# Tightly scoped on purpose: validates that the source lives under one of a
# small allowlist of staging roots and the dest is a bare `jam` or `jam-*`
# filename in /opt/jam/bin/. Cmnd_Alias JAM_INSTALL_BIN in
# /etc/sudoers.d/jam-users whitelists this exact script.
#
# Sources accepted:
#   /home/caleb/jamboree/target/release/...   (interactive caleb builds)
#   /home/maestro/.jam/staging/...            (patch-agent staging)
#   /home/maestro/.jam/bin/...                (patch-agent runtime bin dir)
#
# Usage:
#   sudo -n /opt/jam/sbin/jam-install-bin \
#     /home/caleb/jamboree/target/release/jam-patch-agent \
#     jam-patch-agent

set -euo pipefail

if [[ $# -ne 2 ]]; then
    printf 'usage: jam-install-bin <source-binary> <dest-name>\n' >&2
    exit 64
fi

SRC="$1"
NAME="$2"
ALLOWED_SRC_ROOTS=(
    "/home/caleb/jamboree/target/release"
    "/home/maestro/.jam/staging"
    "/home/maestro/.jam/bin"
)
DEST_ROOT="/opt/jam/bin"

# Reject path components that could allow escaping the source root.
src_ok=0
for root in "${ALLOWED_SRC_ROOTS[@]}"; do
    case "$SRC" in
        "$root"/*) src_ok=1; break ;;
    esac
done
if [[ "$src_ok" -ne 1 ]]; then
    printf 'jam-install-bin: source must be under one of:\n' >&2
    printf '  %s\n' "${ALLOWED_SRC_ROOTS[@]}" >&2
    exit 65
fi
case "$SRC" in
    *..*|*/./*|*$'\n'*|*$'\t'*)
        printf 'jam-install-bin: source path has forbidden components\n' >&2
        exit 65
        ;;
esac

# Dest name must be a bare jam-* filename (no slashes, no leading dot).
# `jam` itself is the one allowed exception: per CLAUDE.md the CLI binary
# drops the prefix, so deploys of the CLI need to land at /opt/jam/bin/jam.
case "$NAME" in
    jam|jam-*) ;;
    *) printf 'jam-install-bin: dest name must be jam or start with jam-\n' >&2; exit 65 ;;
esac
case "$NAME" in
    */*|.*) printf 'jam-install-bin: dest name must be a bare filename\n' >&2; exit 65 ;;
esac

if [[ ! -f "$SRC" ]]; then
    printf 'jam-install-bin: source file does not exist: %s\n' "$SRC" >&2
    exit 66
fi

exec /usr/bin/install -o root -g root -m 0755 "$SRC" "$DEST_ROOT/$NAME"
